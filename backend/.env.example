PORT=5000
NODE_ENV=development
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/nexus
# Optional non-SRV Atlas URI if SRV DNS fails on your network
MONGO_FALLBACK_URI=mongodb://username:password@host1:27017,host2:27017,host3:27017/nexus?ssl=true&replicaSet=atlas-xxxxx-shard-0&authSource=admin&retryWrites=true&w=majority
# Comma-separated DNS servers used for SRV lookup
MONGO_DNS_SERVERS=8.8.8.8,1.1.1.1
JWT_SECRET=replace_with_long_secure_secret
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:3000
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile
